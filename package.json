{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:dev": "nuxt build --dotenv .env.development",
    "dev": "nuxt dev --dotenv .env.development",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "build:pkg": "pnpm -F \"./packages/**\" build",
    "postinstall": "npm run build:pkg & nuxt prepare",
    "genLanguage": "roxy-language-localization --work-dir=./ --target-dir=i18n/locales --source-lang=zh --lang-file-names=zh,en,ru",
    "openapi": "pnpm -F @roxy/backend-api run openapi",
    "deploy:dev": "pnpm build:dev && pnpx tsx ./scripts/deploy-dev.ts",
    "deploy:prod": "pnpm build && pnpx tsx ./scripts/deploy.ts"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^9.5.3",
    "@nuxtjs/seo": "^3.0.3",
    "@primeuix/themes": "^1.0.3",
    "@primevue/forms": "^4.3.3",
    "@vueuse/core": "^13.1.0",
    "axios": "^1.8.4",
    "currency.js": "^2.0.4",
    "es-toolkit": "^1.35.0",
    "jsonwebtoken": "^9.0.2",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-video": "^0.6.3",
    "nuxt": "^3.15.2",
    "primevue": "^4.3.3",
    "qs": "^6.14.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.24.3"
  },
  "packageManager": "pnpm@9.14.4+sha512.c8180b3fbe4e4bca02c94234717896b5529740a6cbadf19fa78254270403ea2f27d4e1d46a08a0f56c89b63dc8ebfd3ee53326da720273794e6200fcf0d184ab",
  "devDependencies": {
    "@nuxtjs/google-fonts": "^3.2.0",
    "@primevue/nuxt-module": "^4.3.3",
    "@roxy/backend-api": "workspace:*",
    "@roxy/language-localization": "workspace:*",
    "@roxy/vite-plugins": "workspace:*",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/qs": "^6.9.18",
    "@unocss/nuxt": "66.1.0-beta.11",
    "adm-zip": "^0.5.16",
    "memfs": "^4.17.0",
    "sass-embedded": "^1.83.4",
    "ssh2": "^1.16.0",
    "unocss": "66.1.0-beta.11",
    "vite-plugin-compression": "^0.5.1",
    "vite-svg-loader": "^5.1.0"
  }
}
