{
  "name": "RoxyBrowser",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "clean": "rimraf .nuxt node_modules/.cache .output",
    "check:zh-proxy": "pnpx tsx ./scripts/check-zh-proxy-wording.ts",
    "fonts:download": "pnpx tsx ./scripts/download-fonts.mts --config=fonts.download.json",
    "prebuild": "pnpm run check:zh-proxy && pnpm run fonts:download",
    "prebuild:dev": "pnpm prebuild",
    "build": "cross-env ENV=production SITE_VARIANT=international NODE_OPTIONS=--max-old-space-size=8192 nuxt build --envName=production",
    "build:dev": "cross-env ENV=development SITE_VARIANT=international NODE_DEBUG=nuxt NODE_OPTIONS=--max-old-space-size=8192 nuxt build --envName=development",
    "build:china": "cross-env ENV=production SITE_VARIANT=china NODE_OPTIONS=--max-old-space-size=8192 nuxt build --envName=production",
    "build:china-dev": "cross-env ENV=development SITE_VARIANT=china NODE_DEBUG=nuxt NODE_OPTIONS=--max-old-space-size=8192 nuxt build --envName=development",
    "dev": "cross-env ENV=development SITE_VARIANT=international nuxt dev --host 0.0.0.0 --envName=development",
    "dev:china": "cross-env ENV=development SITE_VARIANT=china nuxt dev --host 0.0.0.0 --envName=development",
    "dev:h2": "nuxt dev --https --envName=development",
    "generate": "nuxt generate",
    "preview": "cross-env SITE_VARIANT=international NITRO_PORT=3000 PORT=3000 nuxt preview",
    "preview:china": "cross-env SITE_VARIANT=china NITRO_PORT=3001 PORT=3001 nuxt preview",
    "audit:home-preload": "cross-env HOME_PRELOAD_URL=http://localhost:3001 pnpx tsx ./scripts/audit-home-preload.ts",
    "verify:preload-batch1": "cross-env HOME_PRELOAD_URL=http://localhost:3001 pnpx tsx ./scripts/verify-preload-batch1.mjs",
    "analyze": "nuxt analyze",
    "build:pkg": "pnpm -F \"./packages/**\" build",
    "postinstall": "pnpm run build:pkg && nuxt prepare",
    "genLanguage": "roxy-language-localization --work-dir=./ --target-dir=i18n/locales --source-lang=zh --lang-file-names=zh,en,ru",
    "check:cn-sensitive": "roxy-sensitive-check --config=./cn-sensitive.json5",
    "openapi": "pnpm -F @roxy/backend-api run openapi",
    "deploy:dev": "pnpm build:dev && pnpx tsx ./scripts/deploy.ts --target=roxy_home_dev",
    "fix:deploy-symlink:dev": "pnpx tsx ./scripts/fix-deploy-symlink.ts --target=roxy_home_dev",
    "fix:deploy-symlink:china": "pnpx tsx ./scripts/fix-deploy-symlink.ts --target=roxy_home_china",
    "cleanup:deploy-releases:dev": "pnpx tsx ./scripts/cleanup-deploy-releases.ts --target=roxy_home_dev",
    "cleanup:deploy-releases:china-dev": "pnpx tsx ./scripts/cleanup-deploy-releases.ts --target=roxy_home_cn_dev",
    "cleanup:deploy-releases:mobile:dev": "pnpx tsx ./scripts/cleanup-deploy-releases.ts --target=roxy_home_m_dev",
    "cleanup:deploy-releases:test": "pnpx tsx ./scripts/cleanup-deploy-releases.ts --all-test",
    "cleanup:deploy-releases:china": "pnpx tsx ./scripts/cleanup-deploy-releases.ts --target=roxy_home_china",
    "deploy:prod": "pnpm build && pnpx tsx ./scripts/deploy.ts --target=roxy_home",
    "deploy:china": "pnpm build:china && pnpx tsx ./scripts/deploy.ts --target=roxy_home_china",
    "deploy:china-dev": "pnpm build:china-dev && pnpx tsx ./scripts/deploy.ts --target=roxy_home_china_dev",
    "deploy:mobile:dev": "pnpm build:dev && pnpx tsx ./scripts/deploy.ts --target=roxy_home_m_dev",
    "deploy:mobile:prod": "pnpm build && pnpx tsx ./scripts/deploy.ts --target=roxy_home_mobile",
    "rollback:prod": "pnpx tsx ./scripts/rollback.ts --target=roxy_home",
    "rollback:china": "pnpx tsx ./scripts/rollback.ts --target=roxy_home_china",
    "rollback:mobile:prod": "pnpx tsx ./scripts/rollback.ts --target=roxy_home_mobile",
    "server-reload": "pnpx tsx ./scripts/server-reload.ts --env=test",
    "publish:project": "pnpx tsx ./scripts/publish.ts",
    "publish:pc:dev": "pnpx tsx ./scripts/publish.ts --target=roxy_home_dev",
    "publish:pc:prod": "pnpx tsx ./scripts/publish.ts --target=roxy_home",
    "publish:mobile:dev": "pnpx tsx ./scripts/publish.ts --target=roxy_home_m_dev",
    "publish:mobile:prod": "pnpx tsx ./scripts/publish.ts --target=roxy_home_mobile"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@better-scroll/core": "^2.5.1",
    "@fancyapps/ui": "^6.1.7",
    "@fingerprintjs/fingerprintjs": "^5.0.1",
    "@fireworks-js/vue": "^2.10.8",
    "@livechat/widget-vue": "^1.3.4",
    "@mdit-vue/plugin-component": "^3.0.2",
    "@mdit/plugin-embed": "^0.22.1",
    "@nuxt/eslint": "1.10.0",
    "@nuxt/image": "^1.11.0",
    "@nuxtjs/i18n": "^10.1.2",
    "@nuxtjs/seo": "^3.2.2",
    "@nuxtjs/sitemap": "^8.0.15",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/slim": "^3.9.1",
    "@vueuse/components": "^13.9.0",
    "@vueuse/core": "^13.9.0",
    "@vueuse/nuxt": "^13.9.0",
    "axios": "^1.11.0",
    "clsx": "^2.1.1",
    "cobe": "^2.0.1",
    "cross-env": "^7.0.3",
    "currency.js": "^2.0.4",
    "custom-protocol-check": "^1.4.0",
    "dom-align": "^1.12.4",
    "es-toolkit": "^1.35.0",
    "highlight.js": "^11.11.1",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "linkedom": "^0.18.12",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-video": "^0.6.3",
    "matter-js": "0.20.0",
    "medium-zoom": "^1.1.0",
    "minisearch": "^7.2.0",
    "mitt": "^3.0.1",
    "mixpanel-browser": "^2.77.0",
    "motion-plus-vue": "^1.4.0",
    "motion-v": "1.7.4",
    "nuxt": "4.2.1",
    "nuxt-llms": "0.2.0",
    "ogl": "^1.0.11",
    "pangu": "^7.2.0",
    "qs": "^6.14.0",
    "rimraf": "^6.1.3",
    "roxy-cobewebgl": "^1.1.3",
    "swiper": "^11.2.10",
    "tailwind-merge": "^3.4.0",
    "three": "^0.181.2",
    "three-globe": "^2.44.1",
    "vanilla-cookieconsent": "^3.1.0",
    "vue": "^3.5.25",
    "vue-countup-v3": "^1.4.2",
    "vue-router": "^4.6.3",
    "vue-sonner": "^2.0.9",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@clack/prompts": "^0.11.0",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@roxy/backend-api": "workspace:*",
    "@roxy/language-localization": "workspace:*",
    "@roxy/sensitive-check": "workspace:*",
    "@roxy/vite-plugins": "workspace:*",
    "@roxybrowser/jumpserver-deploy": "^1.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/leaflet": "^1.9.8",
    "@types/markdown-it": "^14.1.2",
    "@types/qs": "^6.9.18",
    "@unocss/eslint-plugin": "^66.5.10",
    "@unocss/nuxt": "66.5.10",
    "eslint": "^9.39.1",
    "eslint-plugin-format": "^1.0.2",
    "fast-glob": "^3.3.3",
    "google-fonts-helper": "^3.7.3",
    "memfs": "^4.17.0",
    "opentype.js": "1.3.4",
    "sass": "^1.101.0",
    "sass-embedded": "^1.86.3",
    "ssh2": "^1.16.0",
    "unocss": "66.5.10",
    "vite-imagetools": "^9.0.3",
    "vite-plugin-compression2": "^2.3.1",
    "vite-svg-loader": "^5.1.0"
  },
  "pnpm": {
    "overrides": {
      "chokidar": "3.6.0",
      "ipx": "3.1.1",
      "sharp": "0.34.5"
    },
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
