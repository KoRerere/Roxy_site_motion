{
  "name": "RoxyBrowser",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@9.14.4+sha512.c8180b3fbe4e4bca02c94234717896b5529740a6cbadf19fa78254270403ea2f27d4e1d46a08a0f56c89b63dc8ebfd3ee53326da720273794e6200fcf0d184ab",
  "scripts": {
    "build": "nuxt build --envName=production",
    "build:dev": "cross-env ENV=development nuxt build --envName=development",
    "dev": "nuxt dev --envName=development",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "analyze": "nuxt analyze",
    "build:pkg": "pnpm -F \"./packages/**\" build",
    "postinstall": "npm run build:pkg & nuxt prepare",
    "genLanguage": "roxy-language-localization --work-dir=./ --target-dir=i18n/locales --source-lang=zh --lang-file-names=zh,en,ru",
    "openapi": "pnpm -F @roxy/backend-api run openapi",
    "deploy:dev": "pnpm build:dev && pnpx tsx ./scripts/deploy-dev.ts",
    "deploy:prod": "pnpm build && pnpx tsx ./scripts/deploy.ts",
    "extract-language": "pnpx tsx ./scripts/extract-language.ts",
    "set-language": "pnpx tsx ./scripts/set-language.ts"
  },
  "dependencies": {
    "@better-scroll/core": "^2.5.1",
    "@livechat/widget-vue": "^1.3.4",
    "@nuxt/image": "^1.11.0",
    "@nuxtjs/i18n": "^10.0.5",
    "@nuxtjs/seo": "^3.1.0",
    "@primeuix/themes": "^1.0.3",
    "@primevue/forms": "^4.3.3",
    "@primevue/themes": "^4.3.3",
    "@unocss/preset-mini": "66.4.2",
    "@vueuse/components": "^13.7.0",
    "@vueuse/core": "^13.1.0",
    "axios": "^1.8.4",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
