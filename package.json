    "jsonwebtoken": "^9.0.2",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-video": "^0.6.3",
    "mitt": "^3.0.1",
    "motion-v": "1.7.0",
    "nuxt": "^4.0.3",
    "ogl": "^1.0.11",
    "primevue": "^4.3.3",
    "qs": "^6.14.0",
    "tailwind-merge": "^3.3.1",
    "three": "^0.175.0",
    "three-globe": "^2.42.4",
    "vue": "^3.5.18",
    "vue-countup-v3": "^1.4.2",
